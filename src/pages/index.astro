---
import { getCollection } from "astro:content";
import Meta from "@/components/meta.astro";
import dayjs from "dayjs";
import fs from "node:fs";
import path from "node:path";

const posts = await getCollection("posts");
const sortedProjects = posts.sort((a, b) =>
  dayjs(a.data.createdAt).isAfter(dayjs(b.data.createdAt)) ? -1 : 1,
);

const projectsRoot = path.join(process.cwd(), "public", "projects");
const imageExt = new Set([".png", ".jpg", ".jpeg", ".webp", ".svg"]);

const norm = (value: string) =>
  value
    .normalize("NFD")
    .replace(/\p{M}/gu, "")
    .replace(/\.mdx?$/i, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, " ")
    .trim();

const projectDirs = fs.existsSync(projectsRoot)
  ? fs.readdirSync(projectsRoot, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name)
  : [];

const findProjectDir = (title: string, slug: string) => {
  const titleKey = norm(title);
  const slugKey = norm(slug);
  return (
    projectDirs.find((dir) => {
      const dirKey = norm(dir);
      return dirKey === titleKey || dirKey === slugKey;
    }) ?? null
  );
};

const coverBySlug = new Map<string, string>();
for (const project of sortedProjects) {
  const dir = findProjectDir(project.data.title, project.slug);
  if (!dir) continue;
  const projectDirPath = path.join(projectsRoot, dir);
  const files = fs.readdirSync(projectDirPath);
  const cover = files.find((f) => /^cover\./i.test(f) && imageExt.has(path.extname(f).toLowerCase()));
  if (!cover) continue;
  const coverPath = path.join(projectDirPath, cover);
  const version = fs.statSync(coverPath).mtimeMs.toFixed(0);
  coverBySlug.set(
    project.slug,
    `/projects/${encodeURIComponent(dir)}/${encodeURIComponent(cover)}?v=${version}`,
  );
}
---

<html lang="fr">
	<head>
		<Meta title="Aliénor du Parc" description="Portfolio d'architecture" />
	</head>
	<body class="font-body min-h-screen bg-[#2F4A6D] text-neutral-100 antialiased">
		<header id="top-nav" class="top-nav fixed left-0 right-0 top-0 z-30 hidden items-center justify-between px-6 py-5 md:px-12">
			<a href="#home" class="inline-flex items-center">
				<img src="/favicon1.svg" alt="Logo Aliénor" class="logo-red h-14 w-14 object-contain md:h-16 md:w-16" />
			</a>
			<nav class="absolute left-1/2 -translate-x-1/2">
				<ul class="flex items-center gap-7 text-sm uppercase tracking-[0.2em]">
					<li><a class="module-tab" data-target="vibe" href="#vibe">Vibe</a></li>
					<li><a class="module-tab" data-target="portfolio" href="#portfolio">Portfolio</a></li>
					<li><a class="module-tab" data-target="contact" href="#contact">Contact</a></li>
				</ul>
			</nav>
		</header>

		<main class="relative bg-[#2F4A6D]">
			<p class="font-title fixed right-6 top-8 z-20 text-right text-lg uppercase leading-none tracking-[0.08em] text-[#E53935] md:right-12 md:text-2xl">Alienor du Parc</p>
			<section id="home" data-section="home" class="relative flex min-h-screen flex-col items-center justify-center px-6 pb-14 text-center">
				<div class="relative z-10 flex flex-col items-center gap-6">
					<img src="/favicon1.svg" alt="Logo Aliénor" class="logo-red h-[24rem] w-[24rem] object-contain md:h-[42rem] md:w-[42rem]" />
				</div>
				<nav class="relative z-10 mt-16 md:absolute md:bottom-10 md:mt-0">
					<ul class="flex items-center gap-6 text-sm uppercase tracking-[0.2em] md:gap-10">
						<li><a class="module-tab" data-target="vibe" href="#vibe">Vibe</a></li>
						<li><a class="module-tab" data-target="portfolio" href="#portfolio">Portfolio</a></li>
						<li><a class="module-tab" data-target="contact" href="#contact">Contact</a></li>
					</ul>
				</nav>
			</section>

			<section id="vibe" data-section="vibe" class="min-h-screen w-full px-6 py-24 md:px-12 md:pt-32">
				<h2 class="font-title mb-10 text-center text-5xl uppercase tracking-[0.08em] text-white md:text-6xl">Vibe</h2>
				<div class="grid gap-8 md:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] md:items-start">
					<article id="formation-content" class="p-0">
						<h3 class="m-0 font-title text-3xl uppercase tracking-[0.05em] text-white">Formation</h3>
						<div class="mt-4 space-y-4 text-sm leading-relaxed text-neutral-100">
							<p>Ecole Speciale d'Architecture, Paris - Licence<br />2022 - 2025</p>
							<p>State Academy of Fine Arts, Stuttgart ERASMUS<br />octobre 2024 - fevrier 2025</p>
							<p>Immaconcept, Bordeaux - Bachelor Design d'Espace<br />2021 - 2022</p>
							<p>Lycee St Jacques de Compostelle, Dax<br />2021 - 2023<br />BAC specialites Histoire-Geographie-Geopolitique-Sciences Politiques, Mathematiques<br />Option Histoire Des Arts</p>
							<p>Lycee Isaac de l'Etoile, Poitiers - Internat<br />2018 - 2019<br />Seconde - Option Creation Culture Design<br />option Histoire des Arts</p>
						</div>
					</article>

					<div class="flex items-start justify-center">
						<img id="vibe-photo" src="/194135c7-391d-4556-9044-1ccea4404889.png" alt="Photo de profil d'Alienor" class="w-full max-w-[300px] rounded-2xl object-cover md:w-[300px]" />
					</div>

					<article class="p-0">
						<h3 class="m-0 font-title text-3xl uppercase tracking-[0.05em] text-white">Qui je suis</h3>
						<p class="mt-4 text-sm leading-relaxed text-neutral-100">Bonjour<br />Je suis actuellement etudiante en architecture, passionnee par les nouvelles technologies IA.<br />Si je ne suis pas sur Midjourney ou en train de discuter avec ChatGPT, je suis probablement en train d'ecrire mon podcast ou de courir un autre marathon.</p>
					</article>
				</div>
			</section>

			<section id="portfolio" data-section="portfolio" class="min-h-screen w-full px-6 py-24 md:px-12 md:pt-32">
				<h2 class="font-title mb-10 text-center text-5xl uppercase tracking-[0.08em] text-white md:text-6xl">Portfolio</h2>
				<div class="space-y-4">
					{sortedProjects.map((project) => (
						<a href={`/post/${project.slug}`} class="project-row grid min-h-36 grid-cols-1 items-stretch gap-0 overflow-hidden transition-colors duration-200 md:grid-cols-[40%_60%]">
							<div class="h-full md:aspect-[16/5]">
								<img src={coverBySlug.get(project.slug) ?? "/static/alienor.png"} alt={project.data.title} class="h-full w-full object-cover" />
							</div>
							<div class="flex h-full flex-col justify-center px-6 py-6 md:px-8">
								<p class="text-xs uppercase tracking-[0.16em] opacity-75">{dayjs(project.data.createdAt).format("MM/YYYY")}</p>
								<h3 class="font-title mt-2 text-3xl leading-tight md:text-4xl">{project.data.title}</h3>
							</div>
						</a>
					))}
				</div>
			</section>

			<section id="contact" data-section="contact" class="min-h-screen w-full px-6 py-24 md:px-12 md:pt-32">
				<h2 class="font-title mb-10 text-center text-5xl uppercase tracking-[0.08em] text-white md:text-6xl">Contact</h2>
				<div class="p-8 text-center">
					<p class="text-lg">email : <a href="mailto:alienor@duparc.studio" class="font-semibold underline underline-offset-4">alienor@duparc.studio</a></p>
				</div>
			</section>
		</main>

		<script>
			const topNav = document.getElementById("top-nav");
			const tabs = document.querySelectorAll<HTMLAnchorElement>(".module-tab");
			const sections = document.querySelectorAll<HTMLElement>("[data-section]");
			const contentSections = document.querySelectorAll<HTMLElement>("#vibe, #portfolio, #contact");

			const updateActiveTab = (currentId) => {
				tabs.forEach((tab) => {
					const isActive = tab.dataset.target === currentId;
					tab.classList.toggle("font-bold", isActive);
					tab.classList.toggle("opacity-60", !isActive);
				});
			};

			const navObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.target.id === "home") {
							if (entry.isIntersecting) {
								topNav?.classList.add("hidden");
								topNav?.classList.remove("flex");
								updateActiveTab("");
							} else {
								topNav?.classList.remove("hidden");
								topNav?.classList.add("flex");
							}
						}
					});
				},
				{ threshold: 0.35 },
			);

			const updateSectionFromScroll = () => {
				const marker = window.innerHeight * 0.45;
				let currentId = "";

				contentSections.forEach((section) => {
					const rect = section.getBoundingClientRect();
					if (rect.top <= marker && rect.bottom > marker) {
						currentId = section.id;
					}
				});

				updateActiveTab(currentId);
			};

			sections.forEach((section) => {
				if (section.id === "home") {
					navObserver.observe(section);
				}
			});

			window.addEventListener("scroll", updateSectionFromScroll, { passive: true });
			window.addEventListener("resize", updateSectionFromScroll);
			updateSectionFromScroll();

			const formationContent = document.getElementById("formation-content");
			const vibePhoto = document.getElementById("vibe-photo");

			const alignVibePhotoToFormation = () => {
				if (!formationContent || !vibePhoto) return;
				if (window.innerWidth < 768) {
					vibePhoto.style.height = "auto";
					return;
				}
				vibePhoto.style.height = `${formationContent.getBoundingClientRect().height}px`;
			};

			alignVibePhotoToFormation();
			window.addEventListener("resize", alignVibePhotoToFormation);
			if (formationContent) {
				new ResizeObserver(alignVibePhotoToFormation).observe(formationContent);
			}

		</script>

		<style>
			html {
				scroll-behavior: smooth;
			}

			.module-tab {
				color: rgb(255 255 255);
				transition: opacity 180ms ease;
			}

			.top-nav {
				background: linear-gradient(to bottom, rgba(47, 74, 109, 0.86) 0%, rgba(47, 74, 109, 0.55) 62%, rgba(47, 74, 109, 0) 100%);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
			}

			.project-row {
				background-color: rgba(255, 255, 255, 0.08);
				color: rgb(248 248 248);
			}

			.project-row:hover {
				background-color: rgb(229, 57, 53);
				color: rgb(255 255 255);
			}

			.logo-red {
				filter: brightness(0) saturate(100%) invert(33%) sepia(98%) saturate(2209%) hue-rotate(339deg) brightness(91%) contrast(93%);
			}
		</style>
	</body>
</html>
