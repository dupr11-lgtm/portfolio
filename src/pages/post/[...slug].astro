---
import { type CollectionEntry, getCollection } from "astro:content";
import Meta from "@/components/meta.astro";
import { ClipboardIcon, StarIcon } from "@lucide/astro";
import dayjs from "dayjs";
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  const paths = [];

  for (const post of posts) {
    paths.push(
      {
        params: { slug: post.slug },
        props: post,
      },
      {
        params: { slug: `${post.slug}.md` },
        props: post,
      },
    );
  }

  return paths;
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;

const projectsRoot = path.join(process.cwd(), "public", "projects");
const imageExt = new Set([".png", ".jpg", ".jpeg", ".webp", ".svg"]);

const norm = (value: string) =>
  value
    .normalize("NFD")
    .replace(/\p{M}/gu, "")
    .replace(/\.mdx?$/i, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, " ")
    .trim();

const projectDirs = fs.existsSync(projectsRoot)
  ? fs.readdirSync(projectsRoot, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name)
  : [];

const dirName =
  projectDirs.find((dir) => {
    const key = norm(dir);
    return key === norm(post.data.title) || key === norm(post.slug);
  }) ?? null;

const postImages = dirName
  ? fs
      .readdirSync(path.join(projectsRoot, dirName))
      .filter((f) => imageExt.has(path.extname(f).toLowerCase()))
      .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" }))
  : [];

const coverImage = postImages.find((f) => /^cover\./i.test(f)) ?? null;
const galleryImages = postImages.filter((f) => f !== coverImage);

const toImageUrl = (fileName: string) =>
  `/projects/${encodeURIComponent(dirName ?? "")}/${encodeURIComponent(fileName)}`;

if (Astro.url.pathname.endsWith(".md")) {
  const markdown = `${post.data.title}\n${post.body}`;

  return new Response(markdown);
}

const { Content } = await post.render();
---

<html lang="fr">
    <head>
        <Meta
            title="Reactive"
            description="A blog about programming concepts and technologies"
            slug={`/static/${post.slug}.png`}
        />
    </head>
    <body class="font-body bg-[#2F4A6D] text-neutral-100 antialiased">
        <main
            class="w-full mx-auto md:max-w-4xl px-6 py-12 md:py-16 flex flex-col space-y-10"
        >
            <a
                href="/"
                class="inline-flex items-center"
            >
                <img src="/favicon1.svg" alt="Logo Aliénor" class="logo-red h-14 w-14 object-contain" />
            </a>
            <div class="w-full flex flex-col space-y-6">
                <div class="w-full flex flex-col space-y-2 pb-6 border-b border-white/20">
                    <h1 class="font-title text-5xl leading-none tracking-[0.04em] text-white md:text-6xl">
                        {post.data.title}
                    </h1>
                    <div class="flex items-center justify-between">
                        <div
                            class="flex items-center flex-wrap text-sm font-semibold text-neutral-200/80"
                        >
                            <span>
                                <time
                                    datetime={dayjs(post.data.createdAt).format(
                                        "YYYY-MM-DD",
                                    )}
                                >
                                    {
                                        dayjs(post.data.createdAt).format(
                                            "DD/MM/YYYY",
                                        )
                                    }
                                </time>
                            </span>
                            <span>&nbsp;•&nbsp;</span>
                            <address class="whitespace-nowrap not-italic underline">
                                    <a
                                        href={`${post.data.author.url}?ref=duparc.studio`}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    >
                                    {post.data.author.name}
                                </a>
                            </address>
                            {
                                post.data.contributors.length > 0 && (
                                    <>
                                        <span>&nbsp;with&nbsp;</span>
                                        {post.data.contributors.map(
                                            (contributor, index) => (
                                                <>
                                                    <address class="whitespace-nowrap not-italic underline">
                                                        <a
                                                         href={`${contributor.url}?ref=duparc.studio`}
                                                            target="_blank"
                                                            rel="noopener noreferrer"
                                                        >
                                                            {contributor.name}
                                                        </a>
                                                    </address>
                                                    {index <
                                                        post.data.contributors
                                                            .length -
                                                            2 && (
                                                        <span>,&nbsp;</span>
                                                    )}
                                                    {index ===
                                                        post.data.contributors
                                                            .length -
                                                            2 && (
                                                        <span>&nbsp;and&nbsp;</span>
                                                    )}
                                                </>
                                            ),
                                        )}
                                    </>
                                )
                            }
                        </div>
                        <div class="flex items-center space-x-2">
                            <a href={`https://github.com/herbievine/reactive.so`} target="_blank" rel="noreferer noopener">
                                <StarIcon width={18} height={18} class="stroke-neutral-200/70" />
                            </a>
                            <a href={`${Astro.url.origin}/post/${post.slug}.md`}>
                                <ClipboardIcon width={18} height={18} class="stroke-neutral-200/70" />
                            </a>
                        </div>
                    </div>
                </div>
                {
                    coverImage && (
                        <img
                            src={toImageUrl(coverImage)}
                            alt={`${post.data.title} cover`}
                            class="post-image w-full rounded-md cursor-zoom-in"
                        />
                    )
                }
                <article
                    class="prose prose-invert prose-pre:max-h-[600px] prose-img:rounded-md max-w-none md:text-justify"
                >
                    <Content />
                </article>
                {
                    galleryImages.length > 0 && (
                        <section class="grid gap-4 md:grid-cols-2">
                            {galleryImages.map((image) => (
                                <img
                                    src={toImageUrl(image)}
                                    alt={`${post.data.title} image`}
                                    class="post-image w-full rounded-md object-cover cursor-zoom-in"
                                    loading="lazy"
                                />
                            ))}
                        </section>
                    )
                }
            </div>
        </main>
        <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-[#2F4A6D]/95 p-6">
            <button id="lightbox-close" class="absolute right-5 top-4 text-4xl leading-none text-white" aria-label="Fermer">&times;</button>
            <img id="lightbox-image" src="" alt="Image agrandie" class="max-h-[92vh] max-w-[92vw] object-contain" />
        </div>
        <script>
            const images = document.querySelectorAll<HTMLImageElement>("article img, .post-image");
            const lightbox = document.getElementById("lightbox");
            const lightboxImage = document.getElementById("lightbox-image") as HTMLImageElement | null;
            const closeBtn = document.getElementById("lightbox-close");

            const closeLightbox = () => {
                lightbox?.classList.add("hidden");
                lightbox?.classList.remove("flex");
            };

            images.forEach((img) => {
                img.classList.add("cursor-zoom-in");
                img.addEventListener("click", () => {
                    if (!lightboxImage) return;
                    lightboxImage.src = img.currentSrc || img.src;
                    lightboxImage.alt = img.alt || "Image";
                    lightbox?.classList.remove("hidden");
                    lightbox?.classList.add("flex");
                });
            });

            closeBtn?.addEventListener("click", closeLightbox);
            lightbox?.addEventListener("click", (event) => {
                if (event.target === lightbox) closeLightbox();
            });
            window.addEventListener("keydown", (event) => {
                if (event.key === "Escape") closeLightbox();
            });
        </script>
        <style>
            .logo-red {
                filter: brightness(0) saturate(100%) invert(33%) sepia(98%) saturate(2209%) hue-rotate(339deg) brightness(91%) contrast(93%);
            }

            :global(.prose a) {
                color: #e53935;
            }
        </style>
    </body>
</html>
