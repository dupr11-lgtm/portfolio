---
import { type CollectionEntry, getCollection } from "astro:content";
import Meta from "@/components/meta.astro";
import { StarIcon } from "@lucide/astro";
import dayjs from "dayjs";
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  const paths = [];

  for (const post of posts) {
    paths.push(
      {
        params: { slug: post.slug },
        props: post,
      },
      {
        params: { slug: `${post.slug}.md` },
        props: post,
      },
    );
  }

  return paths;
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;

const projectsRoot = path.join(process.cwd(), "public", "projects");
const imageExt = new Set([".png", ".jpg", ".jpeg", ".webp", ".svg"]);

const norm = (value: string) =>
  value
    .normalize("NFD")
    .replace(/\p{M}/gu, "")
    .replace(/\.mdx?$/i, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, " ")
    .trim();

const projectDirs = fs.existsSync(projectsRoot)
  ? fs.readdirSync(projectsRoot, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name)
  : [];

const dirName =
  projectDirs.find((dir) => {
    const key = norm(dir);
    return key === norm(post.data.title) || key === norm(post.slug);
  }) ?? null;

const postImages = dirName
  ? fs
      .readdirSync(path.join(projectsRoot, dirName))
      .filter((f) => imageExt.has(path.extname(f).toLowerCase()))
      .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" }))
  : [];

const preferredPostCoverBySlug = new Map<string, string>([["nakagin-capsule", "cover2.jpeg"]]);
const coverExclusionsBySlug = new Map<string, string[]>([["nakagin-capsule", ["cover.jpg"]]]);

const preferredPostCover = preferredPostCoverBySlug.get(post.slug);
const coverImage =
  (preferredPostCover && postImages.includes(preferredPostCover) && preferredPostCover) ||
  postImages.find((f) => /^cover\./i.test(f)) ||
  null;
const excluded = new Set<string>([coverImage ?? "", ...(coverExclusionsBySlug.get(post.slug) ?? [])]);
const galleryImages = postImages.filter((f) => !excluded.has(f));

const imagePositionByPost = new Map<string, Map<string, string>>([
  ["entre-deux-corps", new Map([["3.png", "50% 64%"]])],
  [
    "structure-beton",
    new Map([
      ["cover.jpg", "50% 62%"],
      ["1.jpg", "50% 62%"],
      ["2.jpg", "50% 62%"],
      ["3.jpg", "50% 62%"],
      ["4.jpg", "50% 62%"],
    ]),
  ],
  ["32-logements", new Map([["3.jpg", "50% 64%"]])],
  ["centre-de-recherches", new Map([["3.jpg", "50% 58%"]])],
  ["ecole-sad", new Map([["cover.jpg", "50% 64%"]])],
  ["nakagin-capsule", new Map([["2.png", "50% 0%"]])],
  ["stage-simon-1", new Map([["cover.png", "50% 82%"]])],
  ["stage-chantier", new Map([["2.png", "40% 36%"]])],
]);

const imageTransformByPost = new Map<string, Map<string, string>>();

const getImagePosition = (fileName: string) =>
  imagePositionByPost.get(post.slug)?.get(fileName) ?? "50% 50%";

const getImageTransform = (fileName: string) =>
  imageTransformByPost.get(post.slug)?.get(fileName) ?? "";

const isFestivalPost = post.slug === "festival--structure-temporaire";
const findFestivalImage = (index: string) =>
  galleryImages.find((image) => image.startsWith(`${index}.`)) ?? null;
const festivalMosaicLeft = findFestivalImage("3");
const festivalMosaicRight = [findFestivalImage("4"), findFestivalImage("5"), findFestivalImage("6")].filter(
  (image): image is string => Boolean(image),
);
const festivalMosaicSet = new Set<string>([
  ...(festivalMosaicLeft ? [festivalMosaicLeft] : []),
  ...festivalMosaicRight,
]);
const festivalRegularImages = isFestivalPost
  ? galleryImages.filter((image) => !festivalMosaicSet.has(image))
  : galleryImages;
const hasFestivalMosaic =
  isFestivalPost &&
  Boolean(festivalMosaicLeft) &&
  festivalMosaicRight.length > 0;

const isOriginalFormatImage = (fileName: string) =>
  (post.slug === "festival--structure-temporaire" && fileName === festivalMosaicLeft) ||
  (post.slug === "nakagin-capsule" && fileName === "2.png") ||
  (post.slug === "centre-de-recherches" && fileName === "3.jpg");

const isTopAlignedOriginalImage = (fileName: string) =>
  post.slug === "nakagin-capsule" && fileName === "2.png";

const blueFilledStarSlugs = new Set([
  "entre-deux-corps",
  "podcast",
  "festival--structure-temporaire",
  "chatel",
]);
const isBlueFilledStarProject = blueFilledStarSlugs.has(post.slug);

const toImageUrl = (fileName: string) => {
  const base = `/projects/${encodeURIComponent(dirName ?? "")}/${encodeURIComponent(fileName)}`;
  if (!dirName) return base;
  const fullPath = path.join(projectsRoot, dirName, fileName);
  if (!fs.existsSync(fullPath)) return base;
  const version = fs.statSync(fullPath).mtimeMs.toFixed(0);
  return `${base}?v=${version}`;
};

if (Astro.url.pathname.endsWith(".md")) {
  const markdown = `${post.data.title}\n${post.body}`;

  return new Response(markdown);
}

const { Content } = await post.render();
---

<html lang="fr">
    <head>
        <Meta
            title={`${post.data.title} | Aliénor du Parc`}
            description={post.data.description}
            slug={`/static/${post.slug}.png`}
        />
    </head>
    <body class="font-body bg-[#F9FAF7] text-[#2F4A6D] antialiased">
        <main
            class="w-full mx-auto md:max-w-4xl px-6 py-12 md:py-16 flex flex-col space-y-10"
        >
            <a
                href="/"
                class="inline-flex items-center"
            >
                <img src="/favicon1.svg" alt="Logo Aliénor" class="logo-light h-14 w-14 object-contain" />
            </a>
            <div class="w-full flex flex-col space-y-6">
                <div class="w-full flex flex-col space-y-2 pb-6 border-b border-[#2F4A6D]/25">
                    <h1 class="font-title text-5xl leading-none tracking-[0.04em] text-[#2F4A6D] md:text-6xl">
                        {post.data.title}
                    </h1>
                    {
                        post.slug === "podcast" && (
                            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-[#2F4A6D]/85">
                                <a
                                    href="https://open.spotify.com/show/46YfZTl2c1TjJ9xSDRSDGc?si=2a4a432f3f5e437d"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="underline underline-offset-4"
                                >
                                    double vision : architecture abroad
                                </a>
                            </p>
                        )
                    }
                    {
                        post.slug === "ivresse" && (
                            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-[#2F4A6D]/85">
                                <a
                                    href="/livre/ivresse"
                                    class="underline underline-offset-4"
                                >
                                    14 minutes et 16 heures
                                </a>
                            </p>
                        )
                    }
                    <div class="flex items-center justify-between">
                        <div
                            class="flex items-center flex-wrap text-sm font-semibold text-[#2F4A6D]/80"
                        >
                            <span>
                                <time
                                    datetime={dayjs(post.data.createdAt).format(
                                        "YYYY-MM-DD",
                                    )}
                                >
                                    {
                                        dayjs(post.data.createdAt).format(
                                            "DD/MM/YYYY",
                                        )
                                    }
                                </time>
                            </span>
                            <span>&nbsp;•&nbsp;</span>
                            <span class="whitespace-nowrap">{post.data.author.name}</span>
                            {
                                post.data.contributors.length > 0 && (
                                    <>
                                        <span>&nbsp;with&nbsp;</span>
                                        {post.data.contributors.map(
                                            (contributor, index) => (
                                                <>
                                                    <address class="whitespace-nowrap not-italic underline">
                                                        <a
                                                         href={`${contributor.url}?ref=duparc.studio`}
                                                            target="_blank"
                                                            rel="noopener noreferrer"
                                                        >
                                                            {contributor.name}
                                                        </a>
                                                    </address>
                                                    {index <
                                                        post.data.contributors
                                                            .length -
                                                            2 && (
                                                        <span>,&nbsp;</span>
                                                    )}
                                                    {index ===
                                                        post.data.contributors
                                                            .length -
                                                            2 && (
                                                        <span>&nbsp;and&nbsp;</span>
                                                    )}
                                                </>
                                            ),
                                        )}
                                    </>
                                )
                            }
                        </div>
                        <div class="flex items-center">
                            <StarIcon width={18} height={18} class={isBlueFilledStarProject ? "fill-[#2F4A6D] stroke-[#2F4A6D]" : "stroke-[#2F4A6D]"} />
                        </div>
                    </div>
                </div>
                {
                    coverImage && (
                        <img
                            src={toImageUrl(coverImage)}
                            alt={`${post.data.title} cover`}
                            class="post-image post-media rounded-md cursor-zoom-in"
                            style={`object-position: ${getImagePosition(coverImage)};`}
                        />
                    )
                }
                <article
                    class="prose prose-invert prose-pre:max-h-[600px] max-w-none md:text-justify"
                >
                    <Content />
                </article>
                {
                    festivalRegularImages.length > 0 && (
                        <section class="grid grid-cols-1 gap-4">
                            {festivalRegularImages.map((image) => (
                                <img
                                    src={toImageUrl(image)}
                                    alt={`${post.data.title} image`}
                                    class={`post-image post-media rounded-md cursor-zoom-in ${isOriginalFormatImage(image) ? "post-media-original" : ""} ${isTopAlignedOriginalImage(image) ? "post-media-original-top" : ""}`}
                                    style={`object-position: ${getImagePosition(image)};${getImageTransform(image) ? ` transform: ${getImageTransform(image)};` : ""}`}
                                    loading="lazy"
                                />
                            ))}
                        </section>
                    )
                }
                {
                    hasFestivalMosaic && (
                        <section class="grid grid-cols-1 gap-4 md:grid-cols-2">
                            <div class="festival-half-frame rounded-md">
                                <img
                                    src={toImageUrl(festivalMosaicLeft ?? "")}
                                    alt={`${post.data.title} image`}
                                    class="post-image festival-half-image festival-half-left cursor-zoom-in"
                                    loading="lazy"
                                />
                            </div>
                            <div class="grid grid-cols-1 gap-4">
                                {festivalMosaicRight.map((image) => (
                                    <div class="festival-half-frame rounded-md">
                                        <img
                                            src={toImageUrl(image)}
                                            alt={`${post.data.title} image`}
                                            class="post-image festival-half-image festival-half-right cursor-zoom-in"
                                            loading="lazy"
                                        />
                                    </div>
                                ))}
                            </div>
                        </section>
                    )
                }
            </div>
        </main>
        <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-[#F9FAF7]/95 p-6">
            <button id="lightbox-prev" class="absolute left-5 top-1/2 -translate-y-1/2 text-5xl leading-none text-[#2F4A6D]/90" aria-label="Image precedente">&#8249;</button>
            <button id="lightbox-close" class="absolute right-5 top-4 text-4xl leading-none text-[#2F4A6D]" aria-label="Fermer">&times;</button>
            <button id="lightbox-rotate" class="absolute right-16 top-4 text-3xl leading-none text-[#2F4A6D]/90" aria-label="Rotation 90 degres">&#8635;</button>
            <button id="lightbox-next" class="absolute right-5 top-1/2 -translate-y-1/2 text-5xl leading-none text-[#2F4A6D]/90" aria-label="Image suivante">&#8250;</button>
            <img id="lightbox-image" src="" alt="Image agrandie" class="max-h-[92vh] max-w-[92vw] object-contain" />
        </div>
        <script>
            const images = Array.from(document.querySelectorAll<HTMLImageElement>(".post-image, article img"));
            const lightbox = document.getElementById("lightbox");
            const lightboxImage = document.getElementById("lightbox-image") as HTMLImageElement | null;
            const closeBtn = document.getElementById("lightbox-close");
            const rotateBtn = document.getElementById("lightbox-rotate");
            const prevBtn = document.getElementById("lightbox-prev");
            const nextBtn = document.getElementById("lightbox-next");
            let currentIndex = 0;
            let rotationDeg = 0;

            const applyRotation = () => {
                if (!lightboxImage) return;
                lightboxImage.style.transform = `rotate(${rotationDeg}deg)`;
            };

            const openAt = (index: number) => {
                if (!lightboxImage || images.length === 0) return;
                currentIndex = (index + images.length) % images.length;
                const img = images[currentIndex];
                lightboxImage.src = img.currentSrc || img.src;
                lightboxImage.alt = img.alt || "Image";
                rotationDeg = 0;
                applyRotation();
                lightbox?.classList.remove("hidden");
                lightbox?.classList.add("flex");
            };

            const closeLightbox = () => {
                lightbox?.classList.add("hidden");
                lightbox?.classList.remove("flex");
                rotationDeg = 0;
                applyRotation();
            };

            const showPrev = () => openAt(currentIndex - 1);
            const showNext = () => openAt(currentIndex + 1);
            const rotateImage = () => {
                rotationDeg = (rotationDeg + 90) % 360;
                applyRotation();
            };

            images.forEach((img, index) => {
                img.classList.add("cursor-zoom-in");
                img.addEventListener("click", () => openAt(index));
            });

            closeBtn?.addEventListener("click", closeLightbox);
            rotateBtn?.addEventListener("click", (event) => {
                event.stopPropagation();
                rotateImage();
            });
            prevBtn?.addEventListener("click", (event) => {
                event.stopPropagation();
                showPrev();
            });
            nextBtn?.addEventListener("click", (event) => {
                event.stopPropagation();
                showNext();
            });
            lightbox?.addEventListener("click", (event) => {
                if (event.target === lightbox) closeLightbox();
            });
            window.addEventListener("keydown", (event) => {
                if (event.key === "Escape") closeLightbox();
                if (event.key === "ArrowLeft") showPrev();
                if (event.key === "ArrowRight") showNext();
                if (event.key.toLowerCase() === "r") rotateImage();
            });
        </script>
        <style>
            .logo-light {
                filter: brightness(0) saturate(100%) invert(27%) sepia(24%) saturate(879%) hue-rotate(174deg) brightness(94%) contrast(90%);
            }

            :global(.prose),
            :global(.prose p),
            :global(.prose li),
            :global(.prose h1),
            :global(.prose h2),
            :global(.prose h3),
            :global(.prose h4) {
                color: #2f4a6d;
            }

            :global(.prose a) {
                color: #2f4a6d;
            }

            .post-media,
            :global(.prose img) {
                display: block;
                width: 100%;
                height: 70vh;
                max-height: 70vh;
                object-fit: cover;
                object-position: center;
            }

            .post-media-original {
                height: auto;
                max-height: none;
                object-fit: contain;
            }

            .post-media-original-top {
                height: 70vh;
                max-height: 70vh;
                width: 100%;
                object-fit: contain;
                object-position: top center;
                transform: scale(1.85) translateY(-12%);
                transform-origin: top center;
            }

            .festival-half-frame {
                overflow: hidden;
            }

            .festival-half-image {
                display: block;
                width: 200%;
                max-width: none;
                height: auto;
                max-height: none;
                object-fit: contain;
            }

            .festival-half-left {
                width: 100%;
                transform: none;
            }

            .festival-half-right {
                width: 100%;
                transform: none;
            }

            :global(.prose img) {
                border-radius: 0.375rem;
            }
        </style>
    </body>
</html>
